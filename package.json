{
  "name": "pacioli-app",
  "version": "1.0.0",
  "private": true,
  "description": "Personal Finance Automation Platform",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"vite --host\" \"tsx watch api/server.ts\"",
    "dev:wrangler": "wrangler pages dev dist --compatibility-flag=nodejs_compat --d1=DB",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --fileParallelism=false",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply pacioli-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply pacioli-db --remote"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.17.4",
    "@tanstack/react-query": "^5.101.1",
    "chokidar": "^3.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^11.11.17",
    "hono": "^4.6.14",
    "lucide-react": "^0.454.0",
    "proper-lockfile": "^4.1.2",
    "pino": "^9.2.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "wouter": "^3.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.11.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.4.38",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^8.0.12",
    "vitest": "^1.6.0",
    "wrangler": "^3.101.0"
  }
}
