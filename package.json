{
  "name": "pacioli-app",
  "version": "1.0.0",
  "private": true,
  "description": "Personal Finance Automation Platform",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev dist --compatibility-flag=nodejs_compat --d1=DB=pacioli-db",
    "dev:build-watch": "vite build --watch",
    "dev:node": "concurrently \"vite --host\" \"tsx watch scripts/dev-server.ts\"",
    "build": "tsc -p tsconfig.node.json --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply pacioli-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply pacioli-db --remote",
    "db:seed:local": "tsx scripts/run-seed-d1.ts",
    "db:init": "tsx scripts/init-local-db.ts",
    "db:migrate-journal": "tsx scripts/migrate-journal.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tanstack/react-query": "^5.101.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^11.11.17",
    "hono": "^4.6.14",
    "lucide-react": "^0.454.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "wouter": "^3.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.17.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.10",
    "pino": "^9.2.0",
    "postcss": "^8.4.38",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^8.0.12",
    "vitest": "^1.6.0",
    "wrangler": "^3.101.0"
  }
}
