{
  "name": "@finance-platform/api",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Finance Automation Platform - Backend API Server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --fileParallelism=false",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@finance-platform/ledger-interface": "workspace:*",
    "@finance-platform/shared-types": "workspace:*",
    "@libsql/client": "^0.17.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "pino": "^9.2.0",
    "pino-http": "^10.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^26.0.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
